{
  "title": "The Cabin in the Clearing",
  "author": "Sample Adventure",
  "startScene": "clearing",
  "initialState": {
    "flags": {},
    "inventory": []
  },
  "items": {
    "key": {
      "name": "Brass Key",
      "description": "A small brass key, tarnished with age."
    },
    "lantern": {
      "name": "Oil Lantern",
      "description": "A dented lantern. Still has fuel."
    }
  },
  "scenes": {
    "clearing": {
      "name": "Clearing",
      "background": "#2c2030",
      "description": "You stand in a moonlit clearing. A small wooden cabin slumps against a thicket of pines. A path leads back into the dark woods.",
      "objects": [
        {
          "id": "cabin-door",
          "name": "Cabin Door",
          "rect": { "x": 42, "y": 30, "w": 16, "h": 50 },
          "color": "rgba(140, 90, 50, 0.55)",
          "triggers": {
            "onHover": [
              { "type": "narrate", "text": "A heavy wooden door, banded with iron. There is a brass keyhole." }
            ],
            "onClick": [
              {
                "type": "if",
                "condition": { "type": "flag", "flag": "doorUnlocked" },
                "then": [
                  { "type": "narrate", "text": "The door swings inward on protesting hinges." },
                  { "type": "goto", "scene": "interior" }
                ],
                "else": [
                  {
                    "type": "if",
                    "condition": { "type": "hasItem", "item": "key" },
                    "then": [
                      { "type": "narrate", "text": "The brass key fits the lock. It turns with a soft, dry click." },
                      { "type": "setFlag", "flag": "doorUnlocked", "value": true }
                    ],
                    "else": [
                      { "type": "narrate", "text": "The door is locked. The keyhole is too small for your finger." }
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "id": "rock",
          "name": "Loose Stone",
          "rect": { "x": 12, "y": 78, "w": 9, "h": 10 },
          "color": "rgba(120, 120, 120, 0.4)",
          "triggers": {
            "onHover": [
              { "type": "narrate", "text": "A flat stone near the cabin's foundations. It looks recently disturbed." }
            ],
            "onClick": [
              { "type": "narrate", "text": "You lift the stone. Beneath it, half-buried, a brass key glints in the moonlight." },
              { "type": "addItem", "item": "key" },
              { "type": "hideObject" }
            ]
          }
        },
        {
          "id": "path",
          "name": "Forest Path",
          "rect": { "x": 75, "y": 60, "w": 22, "h": 35 },
          "color": "rgba(40, 30, 60, 0.4)",
          "triggers": {
            "onHover": [
              { "type": "narrate", "text": "The path winds away into the trees. You came from there." }
            ],
            "onClick": [
              { "type": "narrate", "text": "You're not ready to leave yet — there's something here you must understand." }
            ]
          }
        },
        {
          "id": "window",
          "name": "Cabin Window",
          "rect": { "x": 64, "y": 30, "w": 10, "h": 14 },
          "color": "rgba(220, 220, 120, 0.18)",
          "triggers": {
            "onHover": [
              { "type": "narrate", "text": "A window, fogged from the inside. Something flickers within — a candle?" }
            ],
            "onClick": [
              { "type": "narrate", "text": "You press your face to the glass. A single candle burns on a table you cannot quite see." }
            ]
          }
        }
      ]
    },
    "interior": {
      "name": "Inside the Cabin",
      "background": "#1a1018",
      "description": "Inside, the air is dry and smells of old paper. A single candle gutters on a writing desk. A lantern hangs from a hook by the door.",
      "onEnter": [
        {
          "type": "if",
          "condition": { "type": "not", "condition": { "type": "flag", "flag": "visitedInterior" } },
          "then": [
            { "type": "narrate", "speaker": "A voice", "kind": "dialog", "text": "You came. I was beginning to wonder." },
            { "type": "setFlag", "flag": "visitedInterior", "value": true }
          ]
        }
      ],
      "objects": [
        {
          "id": "lantern-hook",
          "name": "Lantern",
          "rect": { "x": 8, "y": 30, "w": 9, "h": 22 },
          "color": "rgba(240, 200, 80, 0.3)",
          "visibleIf": { "type": "not", "condition": { "type": "hasItem", "item": "lantern" } },
          "triggers": {
            "onHover": [
              { "type": "narrate", "text": "An oil lantern on a hook. It looks heavy with fuel." }
            ],
            "onClick": [
              { "type": "narrate", "text": "You lift the lantern from its hook." },
              { "type": "addItem", "item": "lantern" }
            ]
          }
        },
        {
          "id": "desk",
          "name": "Writing Desk",
          "rect": { "x": 35, "y": 50, "w": 30, "h": 30 },
          "color": "rgba(120, 80, 40, 0.45)",
          "triggers": {
            "onHover": [
              { "type": "narrate", "text": "An old writing desk. A single sheet of paper rests on it, face down." }
            ],
            "onClick": [
              {
                "type": "if",
                "condition": { "type": "flag", "flag": "readNote" },
                "then": [
                  { "type": "narrate", "text": "The note still reads: \"Bring the lantern to the cellar.\"" }
                ],
                "else": [
                  { "type": "narrate", "text": "You turn the page over. The handwriting is hurried." },
                  { "type": "narrate", "kind": "dialog", "speaker": "The Note", "text": "Bring the lantern to the cellar." },
                  { "type": "setFlag", "flag": "readNote", "value": true }
                ]
              }
            ]
          }
        },
        {
          "id": "exit",
          "name": "Door (out)",
          "rect": { "x": 80, "y": 25, "w": 14, "h": 60 },
          "color": "rgba(140, 90, 50, 0.35)",
          "triggers": {
            "onClick": [
              { "type": "narrate", "text": "You step back out into the cool night." },
              { "type": "goto", "scene": "clearing" }
            ]
          }
        },
        {
          "id": "trapdoor",
          "name": "Trapdoor",
          "rect": { "x": 40, "y": 82, "w": 18, "h": 12 },
          "color": "rgba(60, 40, 20, 0.6)",
          "visibleIf": { "type": "flag", "flag": "readNote" },
          "triggers": {
            "onHover": [
              { "type": "narrate", "text": "A trapdoor set into the floor. You hadn't noticed it before." }
            ],
            "onClick": [
              {
                "type": "if",
                "condition": { "type": "hasItem", "item": "lantern" },
                "then": [
                  { "type": "narrate", "text": "You light the lantern and descend." },
                  { "type": "goto", "scene": "cellar" }
                ],
                "else": [
                  { "type": "narrate", "text": "Stairs disappear into pitch black. You'll need a light." }
                ]
              }
            ]
          }
        }
      ]
    },
    "cellar": {
      "name": "The Cellar",
      "background": "#0c0810",
      "description": "Lantern-light spills across earthen walls. At the far end of the cellar, someone is waiting — but that, perhaps, is a story for another scene.",
      "objects": [
        {
          "id": "stairs-up",
          "name": "Stairs Up",
          "rect": { "x": 78, "y": 20, "w": 18, "h": 70 },
          "color": "rgba(80, 60, 40, 0.4)",
          "triggers": {
            "onClick": [
              { "type": "narrate", "text": "You climb back up to the cabin." },
              { "type": "goto", "scene": "interior" }
            ]
          }
        },
        {
          "id": "figure",
          "name": "Waiting Figure",
          "rect": { "x": 20, "y": 35, "w": 18, "h": 50 },
          "color": "rgba(180, 180, 220, 0.15)",
          "triggers": {
            "onHover": [
              { "type": "narrate", "text": "The figure does not move. The lantern-light slides off them like water." }
            ],
            "onClick": [
              { "type": "narrate", "kind": "dialog", "speaker": "The Figure", "text": "You found the key, then. Good. There's much to discuss." },
              { "type": "narrate", "kind": "system", "text": "(End of demo.)" }
            ]
          }
        }
      ]
    }
  }
}
